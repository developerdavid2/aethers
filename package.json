{
  "name": "@aether/root",
  "version": "1.0.0",
  "private": true,
  "description": "AETHER - Offline-first inspection platform",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "=== WORKSPACE ===": "========================================",
    "install:all": "pnpm install",
    "clean": "pnpm -r exec rm -rf node_modules dist build && rm -rf node_modules",
    "reset": "pnpm clean && pnpm install:all",
    "=== MOBILE ===": "==========================================",
    "mobile:android": "npm run android --prefix apps/mobile",
    "mobile:start": "npm run start --prefix apps/mobile",
    "mobile:install": "npm install --prefix apps/mobile",
    "=== CONVEX ===": "==========================================",
    "convex": "pnpm --filter @aether/convex",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:logs": "convex logs",
    "=== SHARED PACKAGES ===": "================================",
    "types": "pnpm --filter @aether/shared-types",
    "types:build": "pnpm types build",
    "=== QUALITY ===": "=========================================",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,md}\" \"packages/**/*.{ts,tsx,js,jsx,json,md}\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,jsx,json,md}\" \"packages/**/*.{ts,tsx,js,jsx,json,md}\" \"*.json\" \"*.md\"",
    "=== BUILD ===": "===========================================",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=./packages/*",
    "dev": "turbo run dev",
    "=== UTILS ===": "===========================================",
    "check-deps": "pnpm -r outdated",
    "update-deps": "pnpm -r update",
    "doctor": "pnpm mobile doctor"
  },
  "devDependencies": {
    "convex": "^1.34.1",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
